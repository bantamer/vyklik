# Telegram bot from @BotFather
TELEGRAM_BOT_TOKEN=

# Postgres connection used by both poller and bot
POSTGRES_DSN=postgresql://vyklik:vyklik@postgres:5432/vyklik
POSTGRES_USER=vyklik
POSTGRES_PASSWORD=vyklik
POSTGRES_DB=vyklik

# Poller
POLL_INTERVAL_SECONDS=30
# Working hours of the office (Europe/Warsaw); poller sleeps outside this window.
# Format: comma-separated DOW=HH-HH (DOW: mon|tue|wed|thu|fri|sat|sun)
WORK_HOURS=mon=8-16,tue=8-16,wed=8-16,thu=8-16,fri=8-16

# DUW endpoint (override only for testing)
DUW_STATUS_URL=https://rezerwacje.duw.pl/app/webroot/status_kolejek/query.php?status

# rezerwacje.duw.pl serves an incomplete TLS chain (missing intermediate).
# Set to 1 to skip verification until we ship the intermediate cert in the image.
INSECURE_TLS=1

# Logging
LOG_LEVEL=INFO
